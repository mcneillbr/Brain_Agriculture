# Application
PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=brain_agriculture
DB_SSL=false

# Artillery — sobrescreve o target dos testes de carga (opcional)
# ARTILLERY_TARGET=http://localhost:3000

# ─── Docker / docker-compose ──────────────────────────────────────────────────
# Copie este arquivo para .env e ajuste os valores antes de rodar:
#   cp .env.example .env && docker compose up --build
#
# API_URL  → usado pelo Next.js para rotear /api/* no servidor.
#            Em Docker Compose o valor é "http://api:3000" (definido no compose).
#            Para desenvolvimento local não é necessário definir esta variável.
# API_URL=http://api:3000
